{
  "name": "@karnstack/kino",
  "version": "0.3.0",
  "description": "Themeable React video player with pluggable providers.",
  "license": "MIT",
  "author": "Karn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karnstack/kino.git"
  },
  "homepage": "https://github.com/karnstack/kino#readme",
  "bugs": {
    "url": "https://github.com/karnstack/kino/issues"
  },
  "keywords": [
    "video",
    "player",
    "react",
    "mux",
    "youtube",
    "vimeo",
    "hls",
    "video-player"
  ],
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=24"
  },
  "sideEffects": [
    "**/*.css",
    "./dist/mux.js"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mux": {
      "types": "./dist/mux.d.ts",
      "import": "./dist/mux.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js"
    },
    "./youtube": {
      "types": "./dist/youtube.d.ts",
      "import": "./dist/youtube.js"
    },
    "./vimeo": {
      "types": "./dist/vimeo.d.ts",
      "import": "./dist/vimeo.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "vite --config demo/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@mux/mux-video": "^0.31.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "approvedBuilds": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shiki": "^4.3.0",
    "tailwindcss": "^4.3.1",
    "tsdown": "^0.22.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
